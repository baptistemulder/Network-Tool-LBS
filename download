import { useState, useEffect, useCallback } from "react";

// ─── CONSTANTS ────────────────────────────────────────────────────────────────

const STAGES = ["À contacter", "Message envoyé", "Relance envoyée", "Répondu", "Call planifié", "Done"];
const SECTORS = ["Private Debt", "Leveraged Finance", "Infrastructure Debt", "Restructuring", "DCM"];
const GRADES = ["Analyst", "Associate", "VP", "Director", "MD"];

const TARGET_COMPANIES = {
  "Private Debt": ["Arcmont Asset Management", "Hayfin Capital", "ICG", "Pemberton Capital", "Kartesia", "Ares Management", "Apollo Credit", "HPS Investment Partners", "KKR Credit", "Blackstone Credit", "MV Credit", "Tikehau Capital"],
  "Leveraged Finance": ["Houlihan Lokey", "Rothschild & Co", "PJT Partners", "Goldman Sachs", "JP Morgan", "Barclays", "Deutsche Bank", "BNP Paribas CIB", "Bank of America", "Natixis", "ING"],
  "Infrastructure Debt": ["Macquarie Asset Management", "AXA IM Alts", "Infranity", "Schroders Capital", "Brookfield Asset Management"],
  "Restructuring": ["Houlihan Lokey", "PJT Partners", "Lazard", "Alvarez & Marsal", "FTI Consulting"],
  "DCM": ["Goldman Sachs", "JP Morgan", "Barclays", "Deutsche Bank", "BNP Paribas CIB", "Societe Generale"],
};

const BAPTISTE_BIO = `Baptiste Mulder, French-Dutch, CFA charterholder (all 3 levels first attempt), Master in Management IESEG (FT Top 26 MiM). Starting LBS MFA September 2026. Previously: BNP Paribas CIB Lisbon (Corporate Coverage EMEA), then Analyst at Magellan Asset Finance Paris (promoted after 6-month internship) — structured finance & project finance deals: vessel financing €90m, infrastructure €40m. Targeting Private Debt / Direct Lending or Leveraged Finance roles in London.`;

const STORAGE_KEY = "crm:contacts:v2";
const FOLLOWUP_DAYS = 7;

const SAMPLE_CONTACTS = [
  { id: 1, name: "Sarah Chen", company: "Arcmont Asset Management", role: "Associate - Direct Lending", grade: "Associate", school: "LBS MFA 2021", linkedin: "linkedin.com/in/sarahchen", email: "s.chen@arcmont.com", sector: "Private Debt", stage: "À contacter", notes: "", lastContact: null, followUpDate: null, source: "manual", messageHistory: [] },
  { id: 2, name: "James O'Brien", company: "Hayfin Capital", role: "Analyst - Private Credit", grade: "Analyst", school: "LBS MFA 2023", linkedin: "linkedin.com/in/jamesobrien", email: "", sector: "Private Debt", stage: "Message envoyé", notes: "", lastContact: "2026-02-20", followUpDate: "2026-02-27", source: "manual", messageHistory: [] },
  { id: 3, name: "Marie Dubois", company: "Houlihan Lokey", role: "Analyst - Leveraged Finance", grade: "Analyst", school: "LBS MFA 2022", linkedin: "linkedin.com/in/mariedubois", email: "m.dubois@hl.com", sector: "Leveraged Finance", stage: "Répondu", notes: "Very friendly, proposed a call next week", lastContact: "2026-02-25", followUpDate: null, source: "apollo", messageHistory: [] },
];

// ─── HELPERS ──────────────────────────────────────────────────────────────────

const today = () => new Date().toISOString().split("T")[0];
const addDays = (d, n) => new Date(new Date(d).getTime() + n * 86400000).toISOString().split("T")[0];
const isPast = (d) => d && new Date(d) <= new Date();

const stageStyle = (stage) => ({
  "À contacter":    { bg: "#F1F5F9", color: "#64748B", dot: "#94A3B8" },
  "Message envoyé": { bg: "#EFF6FF", color: "#3B82F6", dot: "#3B82F6" },
  "Relance envoyée":{ bg: "#FFFBEB", color: "#D97706", dot: "#F59E0B" },
  "Répondu":        { bg: "#F0FDF4", color: "#16A34A", dot: "#22C55E" },
  "Call planifié":  { bg: "#F5F3FF", color: "#7C3AED", dot: "#8B5CF6" },
  "Done":           { bg: "#ECFDF5", color: "#065F46", dot: "#10B981" },
}[stage] || { bg: "#F1F5F9", color: "#64748B", dot: "#94A3B8" });

const exportCSV = (contacts) => {
  const headers = ["Name","Company","Role","Grade","Sector","School","Email","LinkedIn","Stage","Last Contact","Follow-up Date","Notes","Source"];
  const rows = contacts.map(c => [
    c.name, c.company, c.role, c.grade, c.sector, c.school,
    c.email, c.linkedin, c.stage, c.lastContact || "", c.followUpDate || "", 
    `"${(c.notes || "").replace(/"/g, '""')}"`, c.source
  ]);
  const csv = [headers, ...rows].map(r => r.join(",")).join("\n");
  const blob = new Blob([csv], { type: "text/csv" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a"); a.href = url; a.download = "networking_crm.csv"; a.click();
};

// ─── MAIN COMPONENT ───────────────────────────────────────────────────────────

export default function NetworkingCRM() {
  const [contacts, setContacts] = useState([]);
  const [loaded, setLoaded] = useState(false);
  const [activeTab, setActiveTab] = useState("pipeline");
  const [selectedContact, setSelectedContact] = useState(null);
  const [showAddContact, setShowAddContact] = useState(false);
  const [showApollo, setShowApollo] = useState(false);
  const [filterSector, setFilterSector] = useState("Tous");
  const [filterStage, setFilterStage] = useState("Tous");
  const [filterGrade, setFilterGrade] = useState("Tous");
  const [newContact, setNewContact] = useState({ name: "", company: "", role: "", grade: "Analyst", school: "", linkedin: "", email: "", sector: "Private Debt", notes: "" });

  // Message generation
  const [generatingMsg, setGeneratingMsg] = useState(false);
  const [analyzingProfile, setAnalyzingProfile] = useState(false);
  const [profileAnalysis, setProfileAnalysis] = useState(null);
  const [generatedMessage, setGeneratedMessage] = useState("");
  const [msgType, setMsgType] = useState("linkedin");
  const [gmailStatus, setGmailStatus] = useState("");

  // Apollo
  const [apolloKey, setApolloKey] = useState("");
  const [apolloSearching, setApolloSearching] = useState(false);
  const [apolloResults, setApolloResults] = useState([]);
  const [apolloError, setApolloError] = useState("");
  const [apolloSector, setApolloSector] = useState("Private Debt");
  const [apolloCompany, setApolloCompany] = useState("");
  const [apolloCustomCompany, setApolloCustomCompany] = useState("");
  const [apolloImported, setApolloImported] = useState(0);
  const [showApiKey, setShowApiKey] = useState(false);

  // Calendar
  const [showCalendar, setShowCalendar] = useState(false);
  const [calendarContact, setCalendarContact] = useState(null);
  const [calEvent, setCalEvent] = useState({ date: "", time: "10:00", platform: "Google Meet" });
  const [calendarStatus, setCalendarStatus] = useState("");

  // ── Storage: load ──
  useEffect(() => {
    (async () => {
      try {
        const res = JSON.parse(localStorage.getItem(STORAGE_KEY));
        setContacts(res || SAMPLE_CONTACTS);
      } catch {
        setContacts(SAMPLE_CONTACTS);
      }
      setLoaded(true);
    })();
  }, []);

  // ── Storage: save on change ──
  useEffect(() => {
    if (!loaded) return;
    localStorage.setItem(STORAGE_KEY, JSON.stringify(contacts));
  }, [contacts, loaded]);

  // ── Derived ──
  const filteredContacts = contacts.filter(c => {
    if (filterSector !== "Tous" && c.sector !== filterSector) return false;
    if (filterStage !== "Tous" && c.stage !== filterStage) return false;
    if (filterGrade !== "Tous" && c.grade !== filterGrade) return false;
    return true;
  });

  const dueFollowUps = contacts.filter(c =>
    (c.stage === "Message envoyé" || c.stage === "Relance envoyée") && isPast(c.followUpDate)
  );

  const stageCount = (s) => contacts.filter(c => c.stage === s).length;

  // ── Analytics ──
  const analytics = {
    total: contacts.length,
    replied: contacts.filter(c => ["Répondu","Call planifié","Done"].includes(c.stage)).length,
    calls: contacts.filter(c => ["Call planifié","Done"].includes(c.stage)).length,
    done: contacts.filter(c => c.stage === "Done").length,
    replyRate: contacts.length ? Math.round(contacts.filter(c => ["Répondu","Call planifié","Done"].includes(c.stage)).length / contacts.filter(c => c.stage !== "À contacter").length * 100) || 0 : 0,
    bySector: SECTORS.map(s => ({
      sector: s,
      total: contacts.filter(c => c.sector === s).length,
      replied: contacts.filter(c => c.sector === s && ["Répondu","Call planifié","Done"].includes(c.stage)).length,
    })),
  };

  // ── Mutations ──
  const updateContact = useCallback((id, patch) => {
    setContacts(prev => prev.map(c => c.id === id ? { ...c, ...patch } : c));
    setSelectedContact(prev => prev?.id === id ? { ...prev, ...patch } : prev);
  }, []);

  const updateContactStage = useCallback((id, stage) => {
    const patch = {
      stage,
      lastContact: today(),
      followUpDate: (stage === "Message envoyé" || stage === "Relance envoyée") ? addDays(today(), FOLLOWUP_DAYS) : undefined,
    };
    if (patch.followUpDate === undefined) delete patch.followUpDate;
    updateContact(id, patch);
    if (stage === "Call planifié") {
      const c = contacts.find(x => x.id === id);
      setCalendarContact(c);
      setShowCalendar(true);
    }
  }, [contacts, updateContact]);

  const addContact = () => {
    if (!newContact.name || !newContact.company) return;
    const c = { ...newContact, id: Date.now(), lastContact: null, followUpDate: null, source: "manual", messageHistory: [] };
    setContacts(prev => [...prev, c]);
    setNewContact({ name: "", company: "", role: "", grade: "Analyst", school: "", linkedin: "", email: "", sector: "Private Debt", notes: "" });
    setShowAddContact(false);
    setSelectedContact(c);
    setActiveTab("contacts");
  };

  // ── Profile Analysis ──
  const analyzeProfile = async (contact) => {
    setAnalyzingProfile(true);
    setProfileAnalysis(null);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{
            role: "user",
            content: `Analyze this networking target for Baptiste Mulder and return ONLY a JSON object (no markdown, no preamble):
Target: ${contact.name}, ${contact.role} at ${contact.company}, ${contact.school}, sector: ${contact.sector}, grade: ${contact.grade || "unknown"}.
Notes: ${contact.notes || "none"}.
Baptiste's profile: ${BAPTISTE_BIO}

Return JSON with these exact keys:
{
  "hookPoints": ["2-3 specific conversation hooks based on their role/company/background"],
  "commonGround": "1 sentence on shared LBS / finance background angle",
  "angleRecommended": "best outreach angle in 1 sentence",
  "toneRecommended": "formal | semi-formal | casual",
  "estimatedResponseRate": "X%",
  "redFlags": "any concerns or leave empty string"
}`
          }]
        })
      });
      const data = await res.json();
      const text = data.content?.find(b => b.type === "text")?.text || "{}";
      const clean = text.replace(/```json|```/g, "").trim();
      setProfileAnalysis(JSON.parse(clean));
    } catch {
      setProfileAnalysis({ hookPoints: ["Could not analyze — proceed manually"], commonGround: "", angleRecommended: "", toneRecommended: "semi-formal", estimatedResponseRate: "N/A", redFlags: "" });
    }
    setAnalyzingProfile(false);
  };

  // ── Message Generation ──
  const generateMessage = async (contact, type, isFollowUp = false) => {
    setGeneratingMsg(true);
    setGeneratedMessage("");
    setGmailStatus("");

    const analysisCtx = profileAnalysis
      ? `Profile analysis: hooks = ${profileAnalysis.hookPoints?.join(", ")}; angle = ${profileAnalysis.angleRecommended}; tone = ${profileAnalysis.toneRecommended}.`
      : "";

    const prompt = isFollowUp
      ? `You are Baptiste Mulder. Write a short, natural follow-up message to ${contact.name}, ${contact.role} at ${contact.company} (${contact.school}). Baptiste sent a first message ${FOLLOWUP_DAYS} days ago asking for a 20-min informational coffee, no reply.
Format: ${type === "linkedin" ? "LinkedIn in English, max 80 words, concise, not pushy" : "Email in English, start with 'Subject:' then blank line then body, max 80 words"}.
Baptiste profile: ${BAPTISTE_BIO}
Rules: natural, brief context reminder, renew request for 20min call.`
      : `You are Baptiste Mulder. Write a personalized, non-generic networking message to ${contact.name}, ${contact.role} at ${contact.company} (${contact.school}), sector ${contact.sector}.
Baptiste profile: ${BAPTISTE_BIO}
${analysisCtx}
Contact notes: ${contact.notes || "none"}.
Goal: request a 20-min informational coffee or call.
Format: ${type === "linkedin" ? "LinkedIn in English, max 200 words, conversational, no template feel" : "Email in English, start with 'Subject:' then blank line then body, max 150 words"}.
Rules:
- Reference LBS connection specifically
- Mention their role at ${contact.company}
- Briefly mention Baptiste's debt/project finance background (Magellan, BNP)
- End with a simple ask for a 20-min call
- Tone: professional but human, not corporate`;

    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{ role: "user", content: prompt }]
        })
      });
      const data = await res.json();
      const text = data.content?.find(b => b.type === "text")?.text || "Generation error.";
      setGeneratedMessage(text);
      // Save to history
      const histEntry = { date: today(), type: isFollowUp ? "followup" : "initial", channel: type, preview: text.slice(0, 80) };
      updateContact(contact.id, { messageHistory: [...(contact.messageHistory || []), histEntry] });
    } catch {
      setGeneratedMessage("API connection error.");
    }
    setGeneratingMsg(false);
  };

  // ── Gmail Draft ──
  const createGmailDraft = async (contact) => {
    if (!generatedMessage || msgType !== "email") return;
    setGmailStatus("Creating Gmail draft...");
    const lines = generatedMessage.split("\n");
    const subjectLine = lines.find(l => l.toLowerCase().startsWith("subject:"));
    const subject = subjectLine ? subjectLine.replace(/^subject:\s*/i, "").trim() : `Networking - LBS MFA - ${contact.company}`;
    const body = lines.filter(l => !l.toLowerCase().startsWith("subject:")).join("\n").trim();
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 200,
          messages: [{ role: "user", content: `Create a Gmail draft email to ${contact.email} with subject "${subject}" and body:\n\n${body}` }],
          mcp_servers: [{ type: "url", url: "https://gmail.mcp.claude.com/mcp", name: "gmail" }]
        })
      });
      if (res.ok) {
        setGmailStatus("✅ Draft created in Gmail — ready to send");
      } else {
        setGmailStatus("⚠️ Gmail error — copy message manually");
      }
    } catch {
      setGmailStatus("⚠️ Gmail error — copy message manually");
    }
  };

  // ── Calendar Event ──
  const createCalendarEvent = async () => {
    if (!calEvent.date || !calendarContact) return;
    setCalendarStatus("Creating calendar event...");
    const dtStart = `${calEvent.date}T${calEvent.time}:00`;
    const dtEnd = `${calEvent.date}T${String(Number(calEvent.time.split(":")[0]) + 0)}:${calEvent.time.split(":")[1]}:00`;
    const description = `Informational call with ${calendarContact.name} (${calendarContact.role} @ ${calendarContact.company})\n\nContext: LBS MFA networking — Baptiste Mulder\nPlatform: ${calEvent.platform}`;
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 200,
          messages: [{
            role: "user",
            content: `Create a Google Calendar event:
Title: "Call - ${calendarContact.name} (${calendarContact.company}) - LBS Networking"
Start: ${dtStart}
Duration: 20 minutes
Description: ${description}
${calendarContact.email ? `Attendee: ${calendarContact.email}` : ""}
Add a ${calEvent.platform} link.`
          }],
          mcp_servers: [{ type: "url", url: "https://gmail.mcp.claude.com/mcp", name: "gmail" }]
        })
      });
      setCalendarStatus(res.ok ? "✅ Event created in Google Calendar" : "⚠️ Calendar error — create manually");
    } catch {
      setCalendarStatus("⚠️ Calendar error — create manually");
    }
  };

  // ── One-click Follow-up ──
  const oneClickFollowUp = async (contact) => {
    setSelectedContact(contact);
    setMsgType("email");
    setProfileAnalysis(null);
    setGeneratedMessage("");
    setGmailStatus("");
    await generateMessage(contact, "email", true);
    updateContactStage(contact.id, "Relance envoyée");
  };

  // ── Apollo ──
  const searchApollo = async () => {
    if (!apolloKey) { setApolloError("Missing Apollo API key"); return; }
    const company = apolloCustomCompany || apolloCompany;
    if (!company) { setApolloError("Select or enter a target company"); return; }
    setApolloSearching(true); setApolloResults([]); setApolloError("");
    try {
      const res = await fetch("https://api.apollo.io/v1/mixed_people/search", {
        method: "POST",
        headers: { "Content-Type": "application/json", "X-Api-Key": apolloKey, "Cache-Control": "no-cache" },
        body: JSON.stringify({ page: 1, per_page: 25, organization_names: [company], person_titles: ["Analyst","Associate","Vice President","Director","Manager","Senior Associate"], q_keywords: "London Business School" }),
      });
      if (!res.ok) throw new Error(`Apollo API error (${res.status})`);
      const data = await res.json();
      const people = data.people || [];
      const lbs = people.filter(p => (p.education || []).some(e => e.school_name?.toLowerCase().includes("london business school") || e.school_name?.toLowerCase().includes("lbs")) || (p.headline || "").toLowerCase().includes("london business school"));
      const results = lbs.length > 0 ? lbs : people.slice(0, 15);
      if (!lbs.length && people.length) setApolloError(`⚠️ No LBS alumni detected among ${people.length} profiles — showing all. Verify manually.`);
      else if (!people.length) setApolloError("No results. Try another company name.");
      setApolloResults(results.map(p => {
        const lbsEdu = (p.education || []).find(e => e.school_name?.toLowerCase().includes("london business school") || e.school_name?.toLowerCase().includes("lbs"));
        return { apolloId: p.id, name: `${p.first_name||""} ${p.last_name||""}`.trim(), company: p.organization?.name || company, role: p.title || "", grade: p.seniority || "Analyst", email: p.email || "", linkedin: p.linkedin_url?.replace(/https?:\/\//,"") || "", school: lbsEdu ? `LBS ${lbsEdu.degree||""} ${lbsEdu.graduation_year||""}`.trim() : "To verify", sector: apolloSector, selected: false };
      }));
    } catch (err) { setApolloError(`Error: ${err.message}`); }
    setApolloSearching(false);
  };

  const importFromApollo = () => {
    const toImport = apolloResults.filter(r => r.selected);
    if (!toImport.length) return;
    setContacts(prev => [...prev, ...toImport.map(r => ({ id: Date.now() + Math.random(), name: r.name, company: r.company, role: r.role, grade: r.grade || "Analyst", school: r.school, linkedin: r.linkedin, email: r.email, sector: r.sector, stage: "À contacter", notes: "", lastContact: null, followUpDate: null, source: "apollo", messageHistory: [] }))]);
    setApolloImported(toImport.length);
    setApolloResults([]); setShowApollo(false);
    setTimeout(() => setApolloImported(0), 4000);
  };

  if (!loaded) return (
    <div style={{ minHeight: "100vh", background: "#0F172A", display: "flex", alignItems: "center", justifyContent: "center" }}>
      <div style={{ color: "#94A3B8", fontFamily: "monospace", fontSize: 14 }}>Loading CRM...</div>
    </div>
  );

  // ═══════════════════════════════════════════════════════════════════════════
  // RENDER
  // ═══════════════════════════════════════════════════════════════════════════

  return (
    <div style={{ minHeight: "100vh", background: "#0F172A", fontFamily: "'DM Sans', system-ui, sans-serif", color: "#E2E8F0" }}>

      {/* ── HEADER ── */}
      <div style={{ background: "#0F172A", borderBottom: "1px solid #1E293B", padding: "16px 28px", position: "sticky", top: 0, zIndex: 40 }}>
        <div style={{ maxWidth: 1300, margin: "0 auto", display: "flex", alignItems: "center", justifyContent: "space-between", flexWrap: "wrap", gap: 12 }}>
          <div>
            <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
              <div style={{ width: 8, height: 8, borderRadius: "50%", background: "#3B82F6", boxShadow: "0 0 8px #3B82F6" }} />
              <span style={{ fontSize: 17, fontWeight: 700, color: "#F1F5F9", letterSpacing: "-0.3px" }}>Networking CRM</span>
              <span style={{ fontSize: 11, color: "#475569", background: "#1E293B", padding: "2px 8px", borderRadius: 4, fontWeight: 500 }}>v2</span>
            </div>
            <div style={{ fontSize: 11, color: "#475569", marginTop: 2 }}>Baptiste Mulder · LBS MFA 2026 · Private Debt & LevFin London</div>
          </div>
          <div style={{ display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap" }}>
            {apolloImported > 0 && <Chip color="#10B981">✓ {apolloImported} imported from Apollo</Chip>}
            {dueFollowUps.length > 0 && <Chip color="#F59E0B" pulse>🔔 {dueFollowUps.length} follow-up{dueFollowUps.length > 1 ? "s" : ""} due</Chip>}
            <Btn ghost onClick={() => exportCSV(filteredContacts)}>↓ CSV</Btn>
            <Btn ghost onClick={() => { setShowApollo(true); setApolloResults([]); setApolloError(""); }}>🔍 Apollo</Btn>
            <Btn primary onClick={() => setShowAddContact(true)}>+ Add</Btn>
          </div>
        </div>
      </div>

      {/* ── TABS ── */}
      <div style={{ background: "#0F172A", borderBottom: "1px solid #1E293B", padding: "0 28px" }}>
        <div style={{ maxWidth: 1300, margin: "0 auto", display: "flex", gap: 0 }}>
          {[
            { id: "pipeline", label: "Pipeline" },
            { id: "contacts", label: `Contacts (${contacts.length})` },
            { id: "followups", label: `Follow-ups${dueFollowUps.length > 0 ? ` · ${dueFollowUps.length}` : ""}`, alert: dueFollowUps.length > 0 },
            { id: "analytics", label: "Analytics" },
          ].map(tab => (
            <button key={tab.id} onClick={() => setActiveTab(tab.id)} style={{ padding: "12px 18px", fontSize: 13, fontWeight: activeTab === tab.id ? 600 : 400, color: activeTab === tab.id ? "#F1F5F9" : "#64748B", borderBottom: activeTab === tab.id ? "2px solid #3B82F6" : "2px solid transparent", background: "none", border: "none", borderBottom: activeTab === tab.id ? "2px solid #3B82F6" : "2px solid transparent", cursor: "pointer", transition: "all .15s", position: "relative" }}>
              {tab.label}
              {tab.alert && <span style={{ marginLeft: 4, width: 6, height: 6, borderRadius: "50%", background: "#F59E0B", display: "inline-block", verticalAlign: "middle" }} />}
            </button>
          ))}
        </div>
      </div>

      {/* ── FILTERS ── */}
      <div style={{ background: "#0F172A", padding: "12px 28px", borderBottom: "1px solid #1E293B" }}>
        <div style={{ maxWidth: 1300, margin: "0 auto", display: "flex", gap: 8, flexWrap: "wrap" }}>
          <Select value={filterSector} onChange={e => setFilterSector(e.target.value)} options={["Tous", ...SECTORS]} placeholder="All sectors" />
          <Select value={filterStage} onChange={e => setFilterStage(e.target.value)} options={["Tous", ...STAGES]} placeholder="All stages" />
          <Select value={filterGrade} onChange={e => setFilterGrade(e.target.value)} options={["Tous", ...GRADES]} placeholder="All grades" />
          {(filterSector !== "Tous" || filterStage !== "Tous" || filterGrade !== "Tous") && (
