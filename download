                <div style={{ maxHeight: 240, overflowY: "auto", display: "flex", flexDirection: "column", gap: 6 }}>
                  {apolloResults.map(r => (
                    <div key={r.apolloId} onClick={() => setApolloResults(p => p.map(x => x.apolloId === r.apolloId ? { ...x, selected: !x.selected } : x))} style={{ display: "flex", alignItems: "center", gap: 10, padding: "10px 12px", background: r.selected ? "#1E3A5F" : "#1E293B", border: `1px solid ${r.selected ? "#3B82F6" : "#293548"}`, borderRadius: 8, cursor: "pointer", transition: "all .15s" }}>
                      <div style={{ width: 18, height: 18, borderRadius: 4, border: `2px solid ${r.selected ? "#3B82F6" : "#475569"}`, background: r.selected ? "#3B82F6" : "transparent", flexShrink: 0, display: "flex", alignItems: "center", justifyContent: "center" }}>
                        {r.selected && <span style={{ color: "#fff", fontSize: 10, fontWeight: 700 }}>✓</span>}
                      </div>
                      <div style={{ flex: 1, minWidth: 0 }}>
                        <div style={{ fontSize: 12, fontWeight: 600, color: "#F1F5F9" }}>{r.name}</div>
                        <div style={{ fontSize: 10, color: "#64748B" }}>{r.role} · {r.company}</div>
                      </div>
                      <div style={{ flexShrink: 0 }}>
                        {r.email ? <span style={{ fontSize: 10, color: "#10B981", background: "#052E16", padding: "2px 6px", borderRadius: 4 }}>✉ Email</span> : <span style={{ fontSize: 10, color: "#475569" }}>No email</span>}
                      </div>
                    </div>
                  ))}
                </div>
                <button onClick={importFromApollo} disabled={apolloResults.filter(r => r.selected).length === 0} style={{ marginTop: 10, width: "100%", padding: 12, background: "#1D4ED8", color: "#fff", border: "none", borderRadius: 10, fontSize: 13, fontWeight: 700, cursor: "pointer", opacity: apolloResults.filter(r => r.selected).length === 0 ? 0.4 : 1 }}>
                  Import {apolloResults.filter(r => r.selected).length} contacts →
                </button>
              </div>
            )}
          </div>
        </Modal>
      )}

      {/* ═══════════════════ ADD CONTACT MODAL ═══════════════════ */}
      {showAddContact && (
        <Modal onClose={() => setShowAddContact(false)} title="Add contact manually">
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
            {[
              { k: "name", label: "Full name *", ph: "Sarah Chen" },
              { k: "company", label: "Company *", ph: "Arcmont Asset Management" },
              { k: "role", label: "Role", ph: "Associate - Direct Lending" },
              { k: "school", label: "LBS cohort", ph: "LBS MFA 2022" },
              { k: "linkedin", label: "LinkedIn", ph: "linkedin.com/in/..." },
              { k: "email", label: "Work email", ph: "firstname@company.com" },
            ].map(f => (
              <div key={f.k}>
                <Label>{f.label}</Label>
                <input value={newContact[f.k]} onChange={e => setNewContact(p => ({ ...p, [f.k]: e.target.value }))} placeholder={f.ph} style={inputStyle} />
              </div>
            ))}
            <div>
              <Label>Grade</Label>
              <Select value={newContact.grade} onChange={e => setNewContact(p => ({ ...p, grade: e.target.value }))} options={GRADES} />
            </div>
            <div>
              <Label>Sector</Label>
              <Select value={newContact.sector} onChange={e => setNewContact(p => ({ ...p, sector: e.target.value }))} options={SECTORS} />
            </div>
            <div style={{ gridColumn: "1 / -1" }}>
              <Label>Notes</Label>
              <textarea value={newContact.notes} onChange={e => setNewContact(p => ({ ...p, notes: e.target.value }))} placeholder="Common connections, talking points..." style={{ ...inputStyle, height: 60, resize: "none" }} />
            </div>
          </div>
          <div style={{ display: "flex", gap: 10, marginTop: 16 }}>
            <Btn ghost onClick={() => setShowAddContact(false)}>Cancel</Btn>
            <Btn primary onClick={addContact} disabled={!newContact.name || !newContact.company}>Add contact</Btn>
          </div>
        </Modal>
      )}

      {/* ═══════════════════ CALENDAR MODAL ═══════════════════ */}
      {showCalendar && calendarContact && (
        <Modal onClose={() => { setShowCalendar(false); setCalendarStatus(""); }} title="📅 Schedule call" subtitle={`${calendarContact.name} · ${calendarContact.company}`}>
          <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
              <div>
                <Label>Date</Label>
                <input type="date" value={calEvent.date} onChange={e => setCalEvent(p => ({ ...p, date: e.target.value }))} style={inputStyle} />
              </div>
              <div>
                <Label>Time</Label>
                <input type="time" value={calEvent.time} onChange={e => setCalEvent(p => ({ ...p, time: e.target.value }))} style={inputStyle} />
              </div>
            </div>
            <div>
              <Label>Platform</Label>
              <Select value={calEvent.platform} onChange={e => setCalEvent(p => ({ ...p, platform: e.target.value }))} options={["Google Meet", "Microsoft Teams", "Zoom", "Phone call"]} />
            </div>
            <Btn primary onClick={createCalendarEvent} disabled={!calEvent.date}>📅 Create calendar event</Btn>
            {calendarStatus && <div style={{ fontSize: 12, color: calendarStatus.startsWith("✅") ? "#10B981" : "#F59E0B", fontWeight: 500 }}>{calendarStatus}</div>}
          </div>
        </Modal>
      )}
    </div>
  );
}

// ─── MICRO COMPONENTS ─────────────────────────────────────────────────────────

function Chip({ children, color = "#3B82F6", pulse }) {
  return (
    <div style={{ fontSize: 11, color, background: `${color}18`, border: `1px solid ${color}40`, padding: "3px 10px", borderRadius: 20, fontWeight: 600, display: "flex", alignItems: "center", gap: 4 }}>
      {pulse && <span style={{ width: 6, height: 6, borderRadius: "50%", background: color, animation: "pulse 1.5s infinite" }} />}
      {children}
    </div>
  );
}

function Btn({ children, onClick, primary, ghost, small, warning, success, disabled }) {
  const bg = primary ? "#1D4ED8" : ghost ? "transparent" : warning ? "#92400E" : success ? "#065F46" : "transparent";
  const color = primary ? "#fff" : ghost ? "#94A3B8" : warning ? "#FCD34D" : success ? "#34D399" : "#94A3B8";
  const border = ghost ? "1px solid #293548" : "none";
  return (
    <button onClick={onClick} disabled={disabled} style={{ padding: small ? "5px 12px" : "8px 16px", fontSize: small ? 11 : 12, fontWeight: 600, background: bg, color: disabled ? "#475569" : color, border, borderRadius: 8, cursor: disabled ? "not-allowed" : "pointer", opacity: disabled ? 0.5 : 1, transition: "all .15s", whiteSpace: "nowrap" }}>
      {children}
    </button>
  );
}

function Select({ value, onChange, options, placeholder }) {
  return (
    <select value={value} onChange={onChange} style={{ ...inputStyle, background: "#1E293B" }}>
      {placeholder && <option value="">{placeholder}</option>}
      {options.map(o => <option key={o} value={o}>{o || placeholder}</option>)}
    </select>
  );
}

function StagePill({ stage, small }) {
  const s = stageStyle(stage);
  return (
    <span style={{ fontSize: small ? 9 : 10, padding: small ? "2px 6px" : "2px 8px", borderRadius: 20, background: s.bg, color: s.color, fontWeight: 600, border: `1px solid ${s.color}30` }}>{stage}</span>
  );
}

function GradePill({ grade }) {
  const colors = { Analyst: "#3B82F6", Associate: "#8B5CF6", VP: "#EC4899", Director: "#F59E0B", MD: "#EF4444" };
  const c = colors[grade] || "#64748B";
  return <span style={{ fontSize: 10, padding: "2px 7px", borderRadius: 4, background: `${c}18`, color: c, fontWeight: 600 }}>{grade || "—"}</span>;
}

function Section({ label, children }) {
  return (
    <div>
      <div style={{ fontSize: 10, fontWeight: 700, color: "#475569", textTransform: "uppercase", letterSpacing: "0.5px", marginBottom: 8 }}>{label}</div>
      {children}
    </div>
  );
}

function Label({ children }) {
  return <div style={{ fontSize: 10, fontWeight: 700, color: "#475569", textTransform: "uppercase", letterSpacing: "0.5px", marginBottom: 6 }}>{children}</div>;
}

function InfoRow({ label, value }) {
  return (
    <div>
      <span style={{ fontSize: 10, fontWeight: 700, color: "#475569", textTransform: "uppercase", letterSpacing: "0.5px" }}>{label}: </span>
      <span style={{ fontSize: 11, color: "#94A3B8" }}>{value}</span>
    </div>
  );
}

function Tag({ label, color = "#475569" }) {
  return <span style={{ fontSize: 10, padding: "2px 8px", background: "#1E293B", color, border: `1px solid ${color}40`, borderRadius: 20, fontWeight: 500 }}>{label}</span>;
}

function LoadingDots({ label }) {
  return <div style={{ fontSize: 12, color: "#64748B", display: "flex", alignItems: "center", gap: 6 }}><span style={{ animation: "spin 1s linear infinite", display: "inline-block" }}>⏳</span>{label}</div>;
}

function Modal({ onClose, title, subtitle, children }) {
  return (
    <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.7)", zIndex: 60, display: "flex", alignItems: "center", justifyContent: "center", padding: 20 }} onClick={onClose}>
      <div style={{ background: "#0F172A", borderRadius: 16, width: "100%", maxWidth: 520, maxHeight: "90vh", overflowY: "auto", border: "1px solid #1E293B", boxShadow: "0 25px 80px rgba(0,0,0,0.6)" }} onClick={e => e.stopPropagation()}>
        <div style={{ padding: "20px 24px 16px", borderBottom: "1px solid #1E293B", display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
          <div>
            <div style={{ fontSize: 16, fontWeight: 700, color: "#F1F5F9" }}>{title}</div>
            {subtitle && <div style={{ fontSize: 11, color: "#475569", marginTop: 2 }}>{subtitle}</div>}
          </div>
          <button onClick={onClose} style={{ fontSize: 20, color: "#475569", background: "none", border: "none", cursor: "pointer" }}>×</button>
        </div>
        <div style={{ padding: 24 }}>{children}</div>
      </div>
    </div>
  );
}

const inputStyle = {
  width: "100%",
  background: "#1E293B",
  border: "1px solid #293548",
  borderRadius: 8,
  padding: "9px 12px",
  fontSize: 12,
  color: "#E2E8F0",
  outline: "none",
  boxSizing: "border-box",
};
